<Window x:Class="PRACT1718.AddEdit"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PRACT1718"
        mc:Ignorable="d"
        x:Name="EditAddWin"
        Height="600" Width="450" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Loaded="Window_Loaded" Title="Добавление записи">
    <Grid Margin="20,0">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>

        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Label Content="Название:" HorizontalAlignment="Left" VerticalAlignment="Center" FontWeight="DemiBold"/>
        <Label Content="Цена ед. товара:" HorizontalAlignment="Left" Grid.Row="1" VerticalAlignment="Center" FontWeight="DemiBold"/>
        <Label Content="Дата поступления:" HorizontalAlignment="Left" Grid.Row="2" VerticalAlignment="Center" FontWeight="DemiBold"/>
        <Label Content="№ партии:" HorizontalAlignment="Left" Grid.Row="3" VerticalAlignment="Center" FontWeight="DemiBold"/>
        <Label Content="Размер партии:" HorizontalAlignment="Left" Grid.Row="4" VerticalAlignment="Center" FontWeight="DemiBold"/>
        <Label Content="Фирма-покупатель:" HorizontalAlignment="Left" Grid.Row="5" VerticalAlignment="Center" FontWeight="DemiBold"/>
        <Label Content="Размер проданной партии:" HorizontalAlignment="Left" Grid.Row="6" VerticalAlignment="Center" FontWeight="DemiBold"/>
        <Label Content="Цена ед. продажи:" HorizontalAlignment="Left" Grid.Row="7" VerticalAlignment="Center" FontWeight="DemiBold"/>
        <Label Content="Дата продажи:" HorizontalAlignment="Left" Grid.Row="8" VerticalAlignment="Center" FontWeight="DemiBold"/>
        <TextBox x:Name="tbNameTov" Grid.Column="1" HorizontalAlignment="Center"  TextWrapping="Wrap" VerticalAlignment="Center" Width="150"/>
        <TextBox x:Name="PriceEd" Grid.Column="1" HorizontalAlignment="Center"  Grid.Row="1" TextWrapping="Wrap" VerticalAlignment="Center" Width="150"/>
        <DatePicker x:Name="dpDataStart" Grid.Column="1" HorizontalAlignment="Center"  Grid.Row="2" VerticalAlignment="Center" Width="150"/>
        <TextBox x:Name="tbNumPart" Grid.Column="1" HorizontalAlignment="Center" Grid.Row="3" TextWrapping="Wrap" VerticalAlignment="Center" Width="150"/>
        <TextBox x:Name="tbSizePart" Grid.Column="1" HorizontalAlignment="Center" Grid.Row="4" TextWrapping="Wrap" VerticalAlignment="Center" Width="150"/>
        <TextBox x:Name="tbNameFirm" Grid.Column="1" HorizontalAlignment="Center" Grid.Row="5" TextWrapping="Wrap" VerticalAlignment="Center" Width="150"/>
        <TextBox x:Name="tbSizeSoldPart" Grid.Column="1" HorizontalAlignment="Center" Grid.Row="6" TextWrapping="Wrap" VerticalAlignment="Center" Width="150"/>
        <TextBox x:Name="tbSoldEd" Grid.Column="1" HorizontalAlignment="Center" Grid.Row="7" TextWrapping="Wrap"  VerticalAlignment="Center" Width="150"/>
        <DatePicker x:Name="dpDateSold" Grid.Column="1" HorizontalAlignment="Center" Grid.Row="8" VerticalAlignment="Center" Width="150"/>
        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" VerticalAlignment="Center" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Сохранить" Margin="10"/>
            <Button Content="Отмена" Margin="10"/>
        </StackPanel>
    </Grid>
</Window>
