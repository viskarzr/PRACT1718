<Window x:Class="PRACT1718.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PRACT1718"
        mc:Ignorable="d"
        x:Name="MainWin"
        Title="Практическая работа №17-18" Height="700" Width="1000" ResizeMode="NoResize" Loaded="Window_Loaded" Initialized="Window_Initialized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Menu VerticalAlignment="Top" Grid.ColumnSpan="2">
            <MenuItem Header="Таблица">
                <MenuItem x:Name="muAdd" Header="Добавить запись"></MenuItem>
                <MenuItem x:Name="muEdit" Header="Изменить запись"></MenuItem>
                <MenuItem x:Name="muDelete" Header="Удалить запись" ></MenuItem>
            </MenuItem>
            <MenuItem Header="О программе">
                <MenuItem x:Name="muInfo" Header="Информация"></MenuItem>
                <MenuItem x:Name="muExit" Header="Выход"></MenuItem>
            </MenuItem>
        </Menu>
        <DataGrid x:Name="dgProduct" Grid.ColumnSpan="4" Grid.RowSpan="2" Grid.Row="1" IsReadOnly="True" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Width="10*" Header="Код" Binding="{Binding Id}" />
                <DataGridTextColumn Width="20*" Header="Наименование" Binding="{Binding NameTovar }"  />
                <DataGridTextColumn Width="10*" Header="Цена ед." Binding="{Binding PriceUnit}" />
                <DataGridTextColumn Width="15*" Header="Дата поступления" Binding="{Binding DateStart}" />
                <DataGridTextColumn Width="10*" Header="№ партии" Binding="{Binding NumberPart}" />
                <DataGridTextColumn Width="10*" Header="Размер" Binding="{Binding SizePart}" />
                <DataGridTextColumn Width="20*" Header="Фирма-покупатель" Binding="{Binding NameFirm}" />
                <DataGridTextColumn Width="15*" Header="Размер продаж" Binding="{Binding SizeRentPart}" />
                <DataGridTextColumn Width="10*" Header="Цена" Binding="{Binding PriceSold}" />
                <DataGridTextColumn Width="15*" Header="Дата продажи" Binding="{Binding DateSold}" />
            </DataGrid.Columns>
        </DataGrid>
        <GroupBox Header="Редактирование таблицы" Grid.Row="3" Margin="5">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button x:Name="btnAdd" Content="Добавить запись" Margin="5" Width="200" Click="btnAdd_Click"/>
                <Button x:Name="btnEdit" Content="Изменить запись" Margin="5" Width="200" Click="btnEdit_Click"/>
                <Button x:Name="btnView" Content="Посмотреть запись" Margin="5" Width="200" Click="btnView_Click"/>
                <Button x:Name="btnDel" Content="Удалить запись" Margin="5" Width="200" Click="btnDel_Click"/>
            </StackPanel>
        </GroupBox>
        <GroupBox Grid.Column="1" Header="Поиск и фильтрация" Grid.Row="3" Margin="5">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Label Content="Поиск по дате поступления:"/>
                <TextBox x:Name="tbFind" TextWrapping="Wrap" Width="200"/>
                <Button x:Name="btnFind" Content="Найти" Width="200" Click="btnFind_Click"/>
                <Label Content="Фильтрация по названию товара:" Margin="0,5,0,0"/>
                <TextBox x:Name="tbFiltr" TextWrapping="Wrap" Width="200"/>
                <Button x:Name="btnFiltred" Content="Фильтровать" Width="200" Click="btnFiltred_Click"/>
            </StackPanel>
        </GroupBox>
        <GroupBox Grid.Column="2" Header="Выборка" Grid.Row="3" Margin="5">
            <StackPanel VerticalAlignment="Center">
                <Label Content="Больше указанной даты:"/>
                <TextBox x:Name="tbStartDate" TextWrapping="Wrap" Width="200"/>
                <Button x:Name="btnDateStartWith" Content="Выбрать" Width="200" Click="btnDateStartWith_Click"/>
                <Label Content="Кол-во поставки больше числа:" Margin="0,5,0,0"/>
                <TextBox x:Name="tbUnitCol" TextWrapping="Wrap" Width="200"/>
                <Button x:Name="btnUnitCountStart" Content="Выбрать" Width="200" Click="btnUnitCountStart_Click"/>
            </StackPanel>
        </GroupBox>
        <GroupBox Grid.Column="3" Header="Удаление/Обновление:" Grid.Row="3">
            <StackPanel VerticalAlignment="Center">
                <Label Content="Обновление фирмы-покупателя:"/>
                <TextBox x:Name="tbNewFirm" TextWrapping="Wrap" Width="200"/>
                <Button x:Name="btnFirmChange" Content="Обновить" Width="200" Click="btnFirmChange_Click"/>
                <Label Content="Удаление по id:" Margin="0,5,0,0"/>
                <TextBox x:Name="tbIdDel" TextWrapping="Wrap"  Width="200"/>
                <Button x:Name="btnDelId" Content="Удалить" Width="200" Click="btnDelId_Click"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
